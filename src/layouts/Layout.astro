---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import StudioMetadata from '../components/StudioMetadata.astro';
import VUMeter from '../components/VUMeter.astro';
import LifestreamBackground from '../components/LifestreamBackground.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Harry Fan", description = "Personal website of Harry Fan" } = Astro.props;
const fullTitle = `${title} | Harry Fan`;
---

<!doctype html>
<html lang="zh-TW" class="min-h-screen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    <!-- Google Fonts: Space Grotesk for Body, Bricolage Grotesque for Headings -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).toString()} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/og-image.jpg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/images/og-image.jpg" />

    <style>
      :root {
        --font-heading: 'Bricolage Grotesque', sans-serif;
        --font-body: 'Space Grotesk', sans-serif;
        
        /* Fluid Typography Scales */
        --text-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
        --text-sm: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
        --text-base: clamp(1rem, 0.9rem + 0.5vw, 1.125rem);
        --text-lg: clamp(1.125rem, 1rem + 0.6vw, 1.25rem);
        --text-xl: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
        --text-2xl: clamp(1.5rem, 1.3rem + 1vw, 2rem);
        --text-3xl: clamp(2rem, 1.75rem + 1.25vw, 2.5rem);
        --text-4xl: clamp(2.5rem, 2.2rem + 1.5vw, 3.5rem);
        --text-hero: clamp(4rem, 10vw + 1rem, 12rem);
      }
      
      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }

      body {
        font-family: var(--font-body);
        font-size: var(--text-base);
        line-height: 1.5;
        position: relative;
        overflow-x: hidden;
      }

      .noise-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 100;
        opacity: 0.05;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
      }

      h1, h2, h3, h4, h5, h6, .font-heading {
        font-family: var(--font-heading);
      }

      /* Brutalist selection */
      ::selection {
        background-color: #000;
        color: #fff;
      }
      .dark ::selection {
        background-color: #fff;
        color: #000;
      }

      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #d1d5db;
        border-radius: 4px;
      }
      .dark ::-webkit-scrollbar-thumb {
        background: #374151;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #9ca3af;
      }

      @media (prefers-reduced-motion: reduce) {
        *, ::before, ::after {
          animation-delay: -1ms !important;
          animation-duration: 1ms !important;
          animation-iteration-count: 1 !important;
          background-attachment: initial !important;
          scroll-behavior: auto !important;
          transition-duration: 0s !important;
          transition-delay: 0s !important;
        }
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-[#fcfcfc] dark:bg-[#000B0D] text-[#111] dark:text-[#eee] transition-colors duration-300">
    <div class="noise-bg"></div>
    <div class="hidden dark:block">
      <LifestreamBackground />
    </div>
    <header class="fixed w-full top-0 z-50 mix-blend-difference text-white pointer-events-none p-6 md:p-10">
      <div class="flex justify-between items-center max-w-[1400px] mx-auto pointer-events-auto">
        <div class="flex items-center gap-6">
          <a href="/" class="text-2xl font-heading font-extrabold tracking-tighter uppercase hover:opacity-70 transition-opacity">HF.</a>
          <div class="hidden md:flex items-center gap-3 px-3 py-1 border border-white/20 rounded-full bg-white/5 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-red-600"></span>
            </span>
            <span class="text-[10px] font-bold tracking-[0.2em] uppercase opacity-80">REC</span>
            <span id="studio-clock" class="text-[10px] font-mono tracking-widest opacity-80 border-l border-white/20 pl-3">00:00:00</span>
          </div>
        </div>
        <ThemeToggle />
      </div>
    </header>

    <main class="flex-1 w-full relative">
      <StudioMetadata />
      <VUMeter />
      <slot />
    </main>

    <script is:inline>
      function updateClock() {
        const now = new Date();
        const clock = document.getElementById('studio-clock');
        if (clock) {
          clock.textContent = now.toLocaleTimeString('en-GB', { hour12: false });
        }
      }
      setInterval(updateClock, 1000);
      updateClock();

      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </body>
</html>