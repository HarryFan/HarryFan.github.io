---
---
<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden bg-[#000B0D]">
  <!-- Energy Strands (SVG) -->
  <svg class="absolute inset-0 w-full h-full opacity-30" preserveAspectRatio="none">
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="blur" />
      <feComposite in="SourceGraphic" in2="blur" operator="over" />
    </filter>
    
    <path class="strand strand-1" d="M-100,200 C200,100 400,300 1200,200 S1600,100 2000,200" fill="none" stroke="#10B981" stroke-width="2" filter="url(#glow)" />
    <path class="strand strand-2" d="M-100,500 C300,400 600,600 1100,500 S1500,400 2000,500" fill="none" stroke="#22D3EE" stroke-width="1.5" filter="url(#glow)" />
    <path class="strand strand-3" d="M-100,800 C400,700 800,900 1300,800 S1700,700 2000,800" fill="none" stroke="#10B981" stroke-width="2.5" filter="url(#glow)" />
  </svg>

  <!-- Mako Particles -->
  <div id="mako-particles" class="absolute inset-0"></div>

  <!-- Backdrop Blur Layer -->
  <div class="absolute inset-0 backdrop-blur-[2px] pointer-events-none"></div>
</div>

<style>
  .strand {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: flow 20s linear infinite;
    opacity: 0.6;
  }

  .strand-1 { animation-duration: 25s; }
  .strand-2 { animation-duration: 35s; animation-delay: -5s; }
  .strand-3 { animation-duration: 30s; animation-delay: -10s; }

  @keyframes flow {
    from { stroke-dashoffset: 2000; }
    to { stroke-dashoffset: 0; }
  }

  /* Particle Animation handled by JS for randomness */
</style>

<script>
  function createParticle() {
    const container = document.getElementById('mako-particles');
    if (!container) return;

    const particle = document.createElement('div');
    const size = Math.random() * 3 + 1;
    const color = Math.random() > 0.5 ? '#10B981' : '#22D3EE';
    
    particle.style.position = 'absolute';
    particle.style.width = `${size}px`;
    particle.style.height = `${size}px`;
    particle.style.backgroundColor = color;
    particle.style.borderRadius = '50%';
    particle.style.boxShadow = `0 0 8px ${color}`;
    particle.style.left = `${Math.random() * 100}%`;
    particle.style.top = '110%';
    particle.style.opacity = (Math.random() * 0.5 + 0.2).toString();
    
    container.appendChild(particle);

    const duration = Math.random() * 15000 + 10000;
    const animation = particle.animate([
      { transform: `translateY(0) translateX(0)`, opacity: particle.style.opacity },
      { transform: `translateY(-120vh) translateX(${(Math.random() - 0.5) * 100}px)`, opacity: 0 }
    ], {
      duration: duration,
      easing: 'linear'
    });

    animation.onfinish = () => particle.remove();
  }

  // Initialize particles
  for(let i = 0; i < 30; i++) {
    setTimeout(() => {
      // Start them at different positions initially
      const container = document.getElementById('mako-particles');
      if (container) {
        createParticle();
        // Adjust the initial top for pre-start particles
        const last = container.lastElementChild as HTMLElement;
        if (last) last.style.top = `${Math.random() * 100}%`;
      }
    }, Math.random() * 5000);
  }

  setInterval(createParticle, 500);
</script>
