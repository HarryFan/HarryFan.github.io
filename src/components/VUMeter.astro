---
---
<div class="fixed right-10 top-1/2 -translate-y-1/2 z-40 hidden xl:flex flex-col gap-1 pointer-events-none p-4 border border-white/10 rounded-lg bg-black/20 backdrop-blur-md">
  <div class="flex flex-col-reverse h-64 gap-[2px]" id="vu-meter-container">
    {Array.from({ length: 24 }).map((_, i) => (
      <div 
        class="vu-bar w-3 h-[2px] bg-white/10 transition-all duration-150"
        data-index={i}
      ></div>
    ))}
  </div>
  <span class="text-[8px] font-mono text-white/40 uppercase tracking-tighter mt-2 text-center">VU Meter</span>
</div>

<style>
  .vu-bar.active-low {
    background-color: #10B981; /* Mako Green */
    box-shadow: 0 0 5px rgba(16, 185, 129, 0.5);
  }
  .vu-bar.active-mid {
    background-color: #22D3EE; /* Aether Cyan */
    box-shadow: 0 0 8px rgba(34, 211, 238, 0.6);
  }
  .vu-bar.active-high {
    background-color: #fff; /* High Peak */
    box-shadow: 0 0 12px #fff;
  }
</style>
