---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Harry Fan - Frontend Developer">
  <div class="min-h-screen flex flex-col justify-center px-6 md:px-12 lg:px-24 pt-32 pb-12 max-w-[1800px] mx-auto w-full relative overflow-hidden spotlight-container">
    
    <div id="hero-container" class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-end mt-12 lg:mt-24 relative z-10">
      <div class="lg:col-span-8">
        <p class="text-[var(--text-xs)] font-bold tracking-[0.2em] uppercase mb-6 opacity-60 animate-fade-in">
          Broadcast from / Digital Garden
        </p>
        <h1 
          class="font-heading text-[var(--text-hero)] leading-[0.85] font-black tracking-tighter uppercase m-0 bg-mako-gradient bg-[length:200%_auto] bg-clip-text text-transparent animate-chrome relative group"
        >
          <span class="block animate-glitch-once">Harry</span>
          <span class="block text-white opacity-10 group-hover:opacity-100 transition-opacity duration-700" style="-webkit-text-stroke: max(2px, 0.02em) currentColor;">Fan</span>
        </h1>
      </div>
      
      <div class="lg:col-span-4 pb-2 lg:pb-8 animate-fade-in-delay-1">
        <div class="w-12 h-1 bg-red-600 mb-8 shadow-glow-red animate-pulse"></div>
        <p class="text-[var(--text-xl)] font-semibold max-w-md leading-tight">
          Frontend Engineer <span class="opacity-40">/</span> Podcast Host
        </p>
        <p class="mt-6 text-[var(--text-base)] opacity-70 max-w-md leading-relaxed">
          捕獲技術訊號，轉化為視覺動能。在前端開發與音頻製作的交界處，探索數位體驗的極限。
        </p>
        <div class="mt-10 flex flex-col gap-4 text-[var(--text-sm)] font-bold tracking-widest uppercase">
          <a href="mailto:harry750110@gmail.com" class="hover:text-red-500 transition-colors w-fit flex items-center gap-2 group">
            <span>Signal_Email</span>
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-32 lg:mt-48 border-t border-white/10 pt-16 pb-24 grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-0 animate-fade-in-delay-2 relative z-10">
      
      <a href="https://harryfan.github.io/harry-portfolio/" class="group relative block md:pr-12 lg:pr-24 border-white/5 hover:border-mako-green/30 transition-colors">
        <div class="relative z-10 flex flex-col h-full">
          <div class="flex justify-between items-start mb-16">
            <span class="font-heading text-2xl font-black tracking-tighter opacity-40 group-hover:opacity-100 group-hover:text-mako-green transition-all">01</span>
            <div class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center transform transition-all duration-500 group-hover:border-mako-green group-hover:bg-mako-green/10 group-hover:shadow-glow-mako group-hover:scale-110">
              <svg class="w-5 h-5 text-white transform group-hover:rotate-45 group-hover:text-mako-green transition-all duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </div>
          </div>
          <h2 class="font-heading text-[clamp(3rem,6vw,6rem)] leading-none font-black uppercase tracking-tighter mb-6 group-hover:text-mako-green transition-colors">Portfolio</h2>
          <p class="text-lg opacity-50 group-hover:opacity-80 mt-auto max-w-sm transition-opacity">探索我的專案與設計作品，包含過去的實務經驗與開發成果。</p>
        </div>
      </a>

      <a href="https://harryfan.github.io/harry-blog/" class="group relative block md:pl-12 lg:pl-24 md:border-l border-white/10 hover:border-aether-cyan/30 transition-colors">
        <div class="relative z-10 flex flex-col h-full">
          <div class="flex justify-between items-start mb-16">
            <span class="font-heading text-2xl font-black tracking-tighter opacity-40 group-hover:opacity-100 group-hover:text-aether-cyan transition-all">02</span>
            <div class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center transform transition-all duration-500 group-hover:border-aether-cyan group-hover:bg-aether-cyan/10 group-hover:shadow-glow-cyan group-hover:scale-110">
              <svg class="w-5 h-5 text-white transform group-hover:rotate-45 group-hover:text-aether-cyan transition-all duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </div>
          </div>
          <h2 class="font-heading text-[clamp(3rem,6vw,6rem)] leading-none font-black uppercase tracking-tighter mb-6 group-hover:text-aether-cyan transition-colors">Journal</h2>
          <p class="text-lg opacity-50 group-hover:opacity-80 mt-auto max-w-sm transition-opacity">分享我的想法、生活經驗與前端技術見解，記錄學習點滴。</p>
        </div>
      </a>

    </div>
  </div>

  <style>
    .spotlight-container {
      --x: 50%;
      --y: 50%;
    }
    
    @media (min-width: 1024px) {
      .spotlight-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle 300px at var(--x) var(--y), rgba(16, 185, 129, 0.1), transparent 100%);
        pointer-events: none;
        z-index: 1;
      }
    }
  </style>

  <script>
    const container = document.querySelector('.spotlight-container') as HTMLElement;
    const vuBars = document.querySelectorAll('.vu-bar');
    
    if (container) {
      window.addEventListener('mousemove', (e) => {
        const { clientX, clientY } = e;
        const rect = container.getBoundingClientRect();
        const x = ((clientX - rect.left) / rect.width) * 100;
        const y = ((clientY - rect.top) / rect.height) * 100;
        
        container.style.setProperty('--x', `${x}%`);
        container.style.setProperty('--y', `${y}%`);
      });
    }

    // VU Meter Scroll Animation with requestAnimationFrame for performance
    let scrollTicking = false;

    window.addEventListener('scroll', () => {
      if (!scrollTicking) {
        window.requestAnimationFrame(() => {
          const scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
          
          vuBars.forEach((bar, i) => {
            const index = parseInt(bar.getAttribute('data-index') || '0');
            const threshold = (index / vuBars.length) * 0.8;
            const noise = Math.random() * 0.2;
            const isActive = scrollPercent > (threshold + noise);
            
            bar.classList.remove('active-low', 'active-mid', 'active-high', 'opacity-20');
            
            if (isActive) {
              if (index > 20) bar.classList.add('active-high');
              else if (index > 12) bar.classList.add('active-mid');
              else bar.classList.add('active-low');
            } else {
              bar.classList.add('opacity-20');
            }
          });
          scrollTicking = false;
        });
        scrollTicking = true;
      }
    }, { passive: true });
  </script>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeUp 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .animate-fade-in-delay-1 {
    animation: fadeUp 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    opacity: 0;
  }

  .animate-fade-in-delay-2 {
    animation: fadeUp 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    opacity: 0;
  }

  @keyframes fadeUp {
    0% {
      opacity: 0;
      transform: translateY(60px);
      filter: blur(4px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
</style>
